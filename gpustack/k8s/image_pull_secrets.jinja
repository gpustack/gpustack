{#-
  Materialise each K8sOptions.image_credentials entry as a
  kubernetes.io/dockerconfigjson Secret in the shared gpustack-system
  namespace, used by both the worker DaemonSets and the operator Job.
-#}
{%- for ips in config.image_pull_secrets %}
---
# Image pull secret for {{ ips.registry }}
apiVersion: v1
kind: Secret
metadata:
  name: {{ ips.name }}
  namespace: {{ config.namespace }}
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: {{ ips.dockerconfigjson_b64 }}
{%- endfor %}
